# DiscoWorld Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# Discogs API (required for collection features, optional for browsing)
# =============================================================================

# Personal access token — get one at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# OAuth 1.0a credentials (optional — enables multi-user login)
# Register an app at https://www.discogs.com/settings/developers
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# User agent (Discogs requires a descriptive user agent)
DISCOGS_USER_AGENT=DiscoWorld/2.0 +https://github.com/benjaminbelaga/discoworld

# =============================================================================
# Frontend (optional)
# =============================================================================

# API base URL (defaults to same origin in production)
# VITE_API_URL=http://localhost:8000

# =============================================================================
# Database paths (auto-detected, override if needed)
# =============================================================================

# DISCOWORLD_DB_PATH=./data/discoworld.db
# DISCOWORLD_USERS_DB_PATH=./data/discoworld_users.db
